8. EXEMPLOS DE CÓDIGO
8.1 Backend - Serviço de Precificação (Node.js)

// backend/services/precificacaoService.js

class PrecificacaoService {
  calcularMargem(anuncio, custos) {
    const precoVenda = anuncio.preco_atual;
    const comissaoML = precoVenda * (custos.taxa_comissao_ml / 100);
    const imposto = precoVenda * (custos.taxa_imposto / 100);
    const acos = precoVenda * (custos.acos_medio / 100);

    const totalDeducoes = 
      comissaoML + 
      imposto + 
      custos.custo_producao + 
      custos.custo_frete_medio + 
      custos.custo_embalagem + 
      acos;

    const lucroUnitario = precoVenda - totalDeducoes;
    const margemReal = (lucroUnitario / precoVenda) * 100;

    return {
      lucroUnitario,
      margemReal,
      breakdown: {
        precoVenda,
        comissaoML,
        imposto,
        acos,
        custoProducao: custos.custo_producao,
        custoFrete: custos.custo_frete_medio,
        custoEmbalagem: custos.custo_embalagem
      }
    };
  }
}

module.exports = new PrecificacaoService();

