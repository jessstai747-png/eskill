# =========================================
# Account Monitor — Environment Variables
# =========================================

# eskill OpenClaw API
ESKILL_BASE_URL=https://eskill.com.br/api/openclaw
ESKILL_TOKEN=your_bearer_token_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Timezone
TZ=America/Sao_Paulo

# SQLite database file (relative to project root)
DB_PATH=./data/monitor.db

# Thresholds (optional overrides)
# DAYS_WARNING=7
# DAYS_ALERT=14
# DAYS_CRITICAL=30
# NEW_ACCOUNT_DAYS=7
# SCORE_247_THRESHOLD=80
