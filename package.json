{
  "scripts": {
    "test": "npm run test:e2e",
    "test:e2e": "mkdir -p .tmp/playwright-transform-cache-0 && TMPDIR=.tmp playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "smoke:prod:ui": "node scripts/playwright_prod_smoke.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^20.0.0"
  }
}
