{
  "scripts": {
    "test": "npm run test:e2e",
    "test:e2e": "mkdir -p .tmp/playwright-transform-cache-0 && TMPDIR=.tmp playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "smoke:prod": "RUN_PROD_VALIDATION=1 PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test production-validation --project=chromium",
    "smoke:prod:ui": "RUN_PROD_VALIDATION=1 PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test production-validation --project=chromium --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0"
  }
}
