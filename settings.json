{
  // ============================================================
  // 🤖 VS CODE COPILOT — CONFIGURAÇÃO PARA MÁXIMA AUTONOMIA
  // ============================================================
  // Criado para: Jess @ AWA Motos
  // Data: Fevereiro 2026
  // Objetivo: Agent trabalhando de forma autônoma sem interrupções
  // ============================================================

  // ──────────────────────────────────────────────────────────────
  // 1. AGENT MODE — CORE
  // ──────────────────────────────────────────────────────────────
  "chat.agent.enabled": true,

  // Auto-corrige erros de diagnóstico (lint, compile, TS) automaticamente
  "github.copilot.chat.agent.autoFix": true,

  // Permite rodar build tasks automaticamente
  "github.copilot.chat.agent.runTasks": true,

  // ──────────────────────────────────────────────────────────────
  // 2. AUTO-APPROVE — O SEGREDO DA AUTONOMIA
  // ──────────────────────────────────────────────────────────────

  // Auto-aprova TODAS as tools (MCP, fetch, etc.)
  // ⚠️ Se preferir mais segurança, comente esta linha e aprove por sessão
  "chat.tools.autoApprove": true,

  // Auto-aprova npm/pnpm/yarn scripts do package.json
  "chat.tools.terminal.autoApproveWorkspaceNpmScripts": true,

  // Lista granular de comandos permitidos/bloqueados no terminal
  "chat.tools.terminal.autoApprove": {
    // ✅ PERMITIDOS — Comandos seguros e de leitura
    "/^git\\s+(status|diff|log|show|add|commit|branch|checkout|stash|fetch|pull)\\b/": true,
    "/^npm\\s+(test|run|install|start|build|init|list|outdated|audit)\\b/": true,
    "/^npx\\b/": true,
    "/^pnpm\\b/": true,
    "/^yarn\\b/": true,
    "/^node\\b/": true,
    "/^python3?\\b/": true,
    "/^pip3?\\s+install\\b/": true,
    "/^tsc\\b/": true,
    "/^tsx\\b/": true,
    "/^ts-node\\b/": true,
    "/^prisma\\b/": true,
    "/^next\\b/": true,
    "/^vite\\b/": true,
    "/^eslint\\b/": true,
    "/^prettier\\b/": true,
    "/^jest\\b/": true,
    "/^vitest\\b/": true,
    "/^playwright\\b/": true,
    "/^curl\\b/": true,
    "/^wget\\b/": true,
    "/^docker\\s+(ps|images|logs|inspect|build|compose)\\b/": true,
    "/^cd\\b/": true,
    "/^ls\\b/": true,
    "/^cat\\b/": true,
    "/^head\\b/": true,
    "/^tail\\b/": true,
    "/^grep\\b/": true,
    "/^find\\b/": true,
    "/^wc\\b/": true,
    "/^echo\\b/": true,
    "/^pwd\\b/": true,
    "/^mkdir\\b/": true,
    "/^cp\\b/": true,
    "/^mv\\b/": true,
    "/^touch\\b/": true,
    "/^which\\b/": true,
    "/^whoami\\b/": true,
    "/^env\\b/": true,
    "/^export\\b/": true,
    "/^source\\b/": true,
    "/^tree\\b/": true,
    "/^du\\b/": true,
    "/^df\\b/": true,
    "/^date\\b/": true,
    "/^sed\\b/": true,
    "/^awk\\b/": true,
    "/^sort\\b/": true,
    "/^uniq\\b/": true,
    "/^diff\\b/": true,
    "/^tar\\b/": true,
    "/^unzip\\b/": true,
    "/^zip\\b/": true,

    // ❌ BLOQUEADOS — Comandos destrutivos ou perigosos
    "rm": false,
    "rmdir": false,
    "kill": false,
    "killall": false,
    "chmod": false,
    "chown": false,
    "chgrp": false,
    "/^sudo\\b/": false,
    "/^su\\b/": false,
    "/^shutdown\\b/": false,
    "/^reboot\\b/": false,
    "/^systemctl\\b/": false,
    "/^git\\s+(push|reset\\s+--hard|revert|clean|force)\\b/": false,
    "/^docker\\s+(rm|rmi|prune|system\\s+prune)\\b/": false,
    "/^dd\\b/": false,
    "/^mkfs\\b/": false,
    "/^fdisk\\b/": false,
    "/^iptables\\b/": false,
    "/^ufw\\b/": false
  },

  // ──────────────────────────────────────────────────────────────
  // 3. COPILOT CHAT — FEATURES ESSENCIAIS
  // ──────────────────────────────────────────────────────────────

  // Memória do Copilot — lembra convenções e preferências entre sessões
  "github.copilot.chat.copilotMemory.enabled": true,

  // Pesquisa agentic de código com #codebase
  "github.copilot.chat.codesearch.enabled": true,

  // Instruções personalizadas injetadas no system message
  "github.copilot.chat.customInstructionsInSystemMessage": true,

  // Usar arquivos de instrução (.github/copilot-instructions.md)
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // Sumarizar histórico quando janela de contexto enche
  "github.copilot.chat.summarizeAgentConversationHistory.enabled": true,

  // Permite alternar entre agent de plano e implementação
  "github.copilot.chat.switchAgent.enabled": true,

  // Review de código habilitado
  "github.copilot.chat.reviewAgent.enabled": true,
  "github.copilot.chat.reviewSelection.enabled": true,

  // Debug command no terminal
  "github.copilot.chat.copilotDebugCommand.enabled": true,

  // Gerar testes via Code Lens
  "github.copilot.chat.generateTests.codeLens": true,

  // Setup de testes habilitado
  "github.copilot.chat.setupTests.enabled": true,

  // Upload de imagem via URL (otimizado)
  "github.copilot.chat.imageUpload.enabled": true,

  // Usar templates de projeto do GitHub
  "github.copilot.chat.useProjectTemplates": true,

  // Criação de workspace agentic
  "github.copilot.chat.newWorkspaceCreation.enabled": true,

  // ──────────────────────────────────────────────────────────────
  // 4. AGENTS — BACKGROUND, CLOUD, CLAUDE
  // ──────────────────────────────────────────────────────────────

  // Background Agent — roda em workspace isolado sem interferir no trabalho
  "github.copilot.chat.backgroundAgent.enabled": true,

  // Cloud Agent — delega para a nuvem
  "github.copilot.chat.cloudAgent.enabled": true,

  // Claude Agent — sessões de codificação via Claude diretamente
  "github.copilot.chat.claudeAgent.enabled": true,

  // ⚠️ Skip Permissions do Claude — APENAS em Dev Container
  // "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,

  // Organization agents e instructions
  "github.copilot.chat.organizationCustomAgents.enabled": true,
  "github.copilot.chat.organizationInstructions.enabled": true,

  // ──────────────────────────────────────────────────────────────
  // 5. GITHUB MCP SERVER
  // ──────────────────────────────────────────────────────────────

  // Servidor MCP do GitHub — pesquisa repos, issues, PRs
  "github.copilot.chat.githubMcpServer.enabled": true,

  // Não bloquear em modo readonly (agent precisa criar issues/PRs)
  "github.copilot.chat.githubMcpServer.readonly": false,

  // Sem lockdown — acesso completo
  "github.copilot.chat.githubMcpServer.lockdown": false,

  // Toolsets padrão
  "github.copilot.chat.githubMcpServer.toolsets": ["default"],

  // ──────────────────────────────────────────────────────────────
  // 6. ANTHROPIC / CLAUDE — CONFIGS ESPECÍFICAS
  // ──────────────────────────────────────────────────────────────

  // Context Editing — gerencia contexto em sessões longas
  "github.copilot.chat.anthropic.contextEditing.enabled": true,

  // Extended Thinking — mais tokens para raciocínio profundo
  "github.copilot.chat.anthropic.thinking.budgetTokens": 16000,

  // Use Messages API (melhor que Chat Completions para Claude)
  "github.copilot.chat.anthropic.useMessagesApi": true,

  // Tool Search — descobre ferramentas dinamicamente
  "github.copilot.chat.anthropic.toolSearchTool.enabled": true,

  // Websearch para Claude BYOK
  "github.copilot.chat.anthropic.tools.websearch.enabled": true,
  "github.copilot.chat.anthropic.tools.websearch.maxUses": 10,

  // Localização para resultados de pesquisa contextualizados
  "github.copilot.chat.anthropic.tools.websearch.userLocation": {
    "city": "Araraquara",
    "region": "São Paulo",
    "country": "BR",
    "timezone": "America/Sao_Paulo"
  },

  // ──────────────────────────────────────────────────────────────
  // 7. LANGUAGE CONTEXT — TYPESCRIPT
  // ──────────────────────────────────────────────────────────────

  // Contexto TypeScript para completions
  "github.copilot.chat.languageContext.typescript.enabled": true,

  // Contexto TS para inline chat
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,

  // Contexto TS para /fix
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,

  // Incluir documentação nos snippets gerados
  "github.copilot.chat.languageContext.typescript.includeDocumentation": true,

  // Itens de contexto — double (mais contexto = melhor)
  "github.copilot.chat.languageContext.typescript.items": "double",

  // Cache timeout para provider de contexto TS
  "github.copilot.chat.languageContext.typescript.cacheTimeout": 500,

  // ──────────────────────────────────────────────────────────────
  // 8. NEXT EDIT SUGGESTIONS (NES)
  // ──────────────────────────────────────────────────────────────

  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.fixes": true,
  "github.copilot.nextEditSuggestions.extendedRange": true,
  "github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges": true,

  // Sugestões de renomeação automáticas
  "github.copilot.renameSuggestions.triggerAutomatically": true,

  // ──────────────────────────────────────────────────────────────
  // 9. RESPONSES API
  // ──────────────────────────────────────────────────────────────

  // Mais esforço de raciocínio
  "github.copilot.chat.responsesApiReasoningEffort": "high",

  // Resumo detalhado do raciocínio
  "github.copilot.chat.responsesApiReasoningSummary": "detailed",

  // ──────────────────────────────────────────────────────────────
  // 10. MODELOS — PLAN & IMPLEMENT
  // ──────────────────────────────────────────────────────────────

  // Modelo para o agente de planejamento (Claude é o melhor para planejar)
  // Formatos válidos: "Model Name (vendor)" ex: "claude-sonnet-4.5 (anthropic)"
  // Deixe vazio para usar o modelo padrão/auto
  // "github.copilot.chat.planAgent.model": "",

  // Modelo para o agente de implementação
  // "github.copilot.chat.implementAgent.model": "",

  // ──────────────────────────────────────────────────────────────
  // 11. COMMIT & PR — INSTRUÇÕES
  // ──────────────────────────────────────────────────────────────

  // Instruções para geração de commit messages
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use conventional commits format: feat:, fix:, refactor:, chore:, docs:, test:, style:, perf:, ci:. Mensagem principal em inglês, curta (max 72 chars). Corpo opcional com detalhes em bullet points. Exemplo: feat: add product search filter for CG 160 accessories"
    }
  ],

  // Instruções para geração de PR descriptions
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    {
      "text": "Use formato: ## What (o que mudou), ## Why (por que), ## How (como foi implementado), ## Testing (como testar). Inclua screenshots se houver mudanças visuais. Liste breaking changes se existirem."
    }
  ],

  // Instruções para code review
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "text": "Foque em: 1) Segurança (SQL injection, XSS, exposição de dados), 2) Performance (queries N+1, memory leaks, renders desnecessários), 3) Tipagem TypeScript (evitar any), 4) Error handling (try/catch adequado), 5) Código morto ou duplicado."
    }
  ],

  // ──────────────────────────────────────────────────────────────
  // 12. TERMINAL & EDITOR — COMPLEMENTARES
  // ──────────────────────────────────────────────────────────────

  // Terminal Chat vai para o Chat View (melhor contexto)
  "github.copilot.chat.terminalChatLocation": "chatView",

  // Editor context no modo agent
  "github.copilot.chat.agent.currentEditorContext.enabled": true,

  // Locale para respostas
  "github.copilot.chat.localeOverride": "pt-BR",

  // Virtual Tools threshold (default é bom)
  // "github.copilot.chat.virtualTools.threshold": 10,

  // ──────────────────────────────────────────────────────────────
  // 13. NOTEBOOK (se usar Jupyter)
  // ──────────────────────────────────────────────────────────────

  "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
  "github.copilot.chat.notebook.followCellExecution.enabled": true

  // ──────────────────────────────────────────────────────────────
  // FIM — Salve e recarregue o VS Code (Ctrl+Shift+P → Reload Window)
  // ──────────────────────────────────────────────────────────────
}
