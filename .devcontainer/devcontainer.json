{
  "name": "eskill-copilot-autonomy",
  "image": "mcr.microsoft.com/devcontainers/php:1-8.2-bookworm",
  "remoteUser": "vscode",
  "runArgs": ["--init"],
  "forwardPorts": [80, 3307],
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "chat.tools.autoApprove": true,
        "chat.tools.terminal.autoApprove": true,
        "chat.tools.terminal.autoApproveWorkspaceNpmScripts": true,
        "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
        "github.copilot.chat.backgroundAgent.enabled": true,
        "github.copilot.chat.cloudAgent.enabled": true,
        "github.copilot.chat.githubMcpServer.enabled": true,
        "github.copilot.chat.codeGeneration.useInstructionFiles": true
      },
      "extensions": [
        // Copilot
        "GitHub.copilot",
        "GitHub.copilot-chat",
        // PHP
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "neilbrayfield.php-docblocker",
        // Git / GitKraken MCP (mcp_gitkraken_*)
        "eamodio.gitlens",
        // Codacy MCP (mcp_codacy_*)
        "codacy.codacy",
        // Context7 MCP (mcp_context7_*)
        "upstash.context7-mcp",
        // Microsoft Fabric MCP (mcp_fabric_*)
        "fabric.vscode-fabric-mcp-server",
        // Browser Automation — Playwright MCP Relay
        "vijaynirmal.playwright-mcp-relay",
        // Chrome DevTools MCP Relay
        "vijaynirmal.chrome-devtools-mcp-relay",
        // Python / Pylance MCP (mcp_pylance_*)
        "ms-python.vscode-pylance",
        "ms-python.python",
        // Code quality
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
