### 4.4 Análise de Concorrentes

```python
import requests
from typing import List, Dict
from collections import Counter

class AnalisadorConcorrentes:
    """
    Analisa fichas técnicas de concorrentes para extrair padrões
    """
    
    BASE_URL = "https://api.mercadolibre.com"
    
    def __init__(self):
        pass
    
    def buscar_concorrentes_similares(
        self, 
        titulo: str, 
        category_id: str, 
        limite: int = 3
    ) -> List[Dict]:
        """
        Busca top N concorrentes similares
        
        Args:
            titulo: Título do seu produto
            category_id: Categoria
            limite: Número de concorrentes a retornar
            
        Returns:
            Lista de anúncios concorrentes
        """
        # Buscar na API de busca do ML
        url = f"{self.BASE_URL}/sites/MLB/search"
        params = {
            'q': titulo,
            'category': category_id,
            'limit': limite * 2,  # Buscar mais para filtrar
            'sort': 'relevance',  # Ordenar por relevância
            'official_store': 'all'
        }
        
        try:
            response = requests.get(url, params=params, timeout=10)
            response.raise_for_status()
            data = response.json()
            
            concorrentes = []
            for item in data.get('results', [])[:limite]:
                # Buscar detalhes completos de cada item
                detalhes = self._get_item_detalhes(item['id'])
                if detalhes:
                    concorrentes.append(detalhes)
            
            return concorrentes
        
        except Exception as e:
            print(f"❌ Erro ao buscar concorrentes: {e}")
            return []
    
    def _get_item_detalhes(self, item_id: str) -> Dict:
        """Busca detalhes completos do item incluindo atributos"""
        url = f"{self.BASE_URL}/items/{item_id}"
        
        try:
            response = requests.get(url, timeout=10)
            response.raise_for_status()
            return response.json()
        except:
            return None
    
    def analisar_atributos_comuns(
        self, 
        concorrentes: List[Dict], 
        atributo_id: str
    ) -> Dict:
        """
        Analisa valores mais comuns para um atributo específico
        
        Args:
            concorrentes: Lista de anúncios concorrentes
            atributo_id: ID do atributo a analisar
            
        Returns:
            Análise com valor mais comum, frequência e confiança
        """
        valores = []
        
        for concorrente in concorrentes:
            attributes = concorrente.get('attributes', [])
            for attr in attributes:
                if attr['id'] == atributo_id:
                    valor = attr.get('value_name') or attr.get('value_id')
                    if valor:
                        valores.append(valor)
        
        if not valores:
            return {
                'atributo_id': atributo_id,
                'valor_sugerido': None,
                'frequencia': 0,
                'confianca': 0,
                'distribuicao': {}
            }
        
        # Contar frequências
        counter = Counter(valores)
        valor_mais_comum, frequencia = counter.most_common(1)[0]
        
        # Calcular confiança (% de concordância)
        confianca = (frequencia / len(concorrentes)) * 100
        
        return {
            'atributo_id': atributo_id,
            'valor_sugerido': valor_mais_comum,
            'frequencia': frequencia,
            'total_concorrentes': len(concorrentes),
            'confianca': round(confianca, 1),
            'distribuicao': dict(counter)
        }
    
    def gerar_relatorio_benchmark(
        self, 
        concorrentes: List[Dict], 
        lacunas: List[str]
    ) -> Dict:
        """
        Gera relatório completo de benchmark
        
        Args:
            concorrentes: Lista de concorrentes
            lacunas: Lista de IDs de atributos faltantes
            
        Returns:
            Relatório com sugestões para cada lacuna
        """
        relatorio = {
            'total_concorrentes_analisados': len(concorrentes),
            'sugestoes': []
        }
        
        for atributo_id in lacunas:
            analise = self.analisar_atributos_comuns(concorrentes, atributo_id)
            
            if analise['valor_sugerido']:
                relatorio['sugestoes'].append({
                    'atributo': atributo_id,
                    'valor': analise['valor_sugerido'],
                    'confianca': analise['confianca'],
                    'origem': '🏆 Benchmark de concorrentes',
                    'justificativa': f"{analise['frequencia']} de {analise['total_concorrentes']} concorrentes usam este valor"
                })
        
        return relatorio


