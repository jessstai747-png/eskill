            if lacuna['obrigatorio'] or lacuna['prioridade'] >= 7:
                print(f"  🤖 Consultando IA para {attr_nome}...")
                sugestao_ia = self._inferir_com_ia(
                    titulo=titulo,
                    attr_nome=attr_nome,
                    attr_id=attr_id,
                    valores_possiveis=lacuna.get('valores_possiveis'),
                    dados_contexto=dados_titulo['extraido']
                )
                
                if sugestao_ia:
                    sugestoes.append(sugestao_ia)
                    continue
            
            # Estratégia 4: Valor padrão (último recurso)
            valor_padrao = self._obter_valor_padrao(lacuna)
            if valor_padrao:
                sugestoes.append(Sugestao(
                    atributo_id=attr_id,
                    atributo_nome=attr_nome,
                    valor_sugerido=valor_padrao,
                    origem=OrigemSugestao.PADRAO,
                    confianca=0.5,
                    justificativa="Valor padrão da categoria",
                    alternativas=lacuna.get('valores_possiveis', [])[:3]
                ))
        
        # Ordenar por confiança
        sugestoes_ordenadas = sorted(sugestoes, key=lambda x: x.confianca, reverse=True)
        
        return sugestoes_ordenadas
    
    def _inferir_com_ia(
        self,
        titulo: str,
        attr_nome: str,
        attr_id: str,
        valores_possiveis: Optional[List[str]],
        dados_contexto: Dict
    ) -> Optional[Sugestao]:
        """
        Usa GPT-4 para inferir valor de atributo baseado em contexto
        """
        # Construir prompt contextual
        prompt = f"""Você é um especialista em e-commerce analisando produtos do Mercado Livre.

PRODUTO: {titulo}

INFORMAÇÕES JÁ CONHECIDAS:
{self._formatar_contexto(dados_contexto)}

TAREFA: Inferir o valor do atributo "{attr_nome}" ({attr_id})

"""
        
        if valores_possiveis:
            prompt += f"""VALORES POSSÍVEIS (escolha UM):
{chr(10).join(f"- {v}" for v in valores_possiveis[:10])}

"""
        
        prompt += """INSTRUÇÕES:
1. Analise o título e as informações conhecidas
2. Use conhecimento geral sobre produtos
3. Seja conservador - se não tiver certeza, retorne "INCERTO"
4. Responda APENAS com o valor, sem explicações

RESPOSTA:"""
        
        try:
            response = openai.chat.completions.create(
                model="gpt-4",
                messages=[
                    {"role": "system", "content": "Você é um assistente especializado em e-commerce."},
                    {"role": "user", "content": prompt}
                ],
                temperature=0.3,
                max_tokens=50
            )
            
            valor = response.choices[0].message.content.strip()
            
            # Validar resposta
            if valor == "INCERTO" or len(valor) > 100:
                return None
            
            # Se houver valores possíveis, verificar se a resposta está na lista
            if valores_possiveis and valor not in valores_possiveis:
                # Tentar match parcial
                for vp in valores_possiveis:
                    if valor.lower() in vp.lower() or vp.lower() in valor.lower():
                        valor = vp
                        break
                else:
                    return None  # Não encontrou match
            
            return Sugestao(
                atributo_id=attr_id,
                atributo_nome=attr_nome,
                valor_sugerido=valor,
                origem=OrigemSugestao.IA,
                confianca=0.7,
                justificativa="Inferido por IA baseado em contexto",
                alternativas=valores_possiveis[:3] if valores_possiveis else []
            )
        
        except Exception as e:
            print(f"  ⚠️ Erro na inferência IA: {e}")
            return None
    
    def _formatar_contexto(self, dados: Dict) -> str:
        """Formata dados de contexto para o prompt"""
        if not dados:
            return "Nenhuma informação adicional disponível."
        
        linhas = []
        for k, v in dados.items():
            linhas.append(f"- {k}: {v}")
        return "\n".join(linhas)
    
    def _obter_valor_padrao(self, lacuna: Dict) -> Optional[str]:
        """Obtém valor padrão para uma lacuna"""
        # Valores padrão comuns
        defaults = {
            'ITEM_CONDITION': 'Novo',
            'WARRANTY_TYPE': 'Garantia do vendedor',
            'PACKAGE_WEIGHT': '1 kg',
            'SELLER_SKU': 'N/A',
        }
        
        if lacuna['id'] in defaults:
            return defaults[lacuna['id']]
        
        # Se houver valores possíveis, retornar o primeiro
        if lacuna.get('valores_possiveis'):
            return lacuna['valores_possiveis'][0]
        
        return None
    
    def exportar_json(self, sugestoes: List[Sugestao]) -> List[Dict]:
        """Exporta sugestões para formato JSON"""
        return [
            {
                'atributo_id': s.atributo_id,
                'atributo_nome': s.atributo_nome,
                'valor_sugerido': s.valor_sugerido,
                'origem': s.origem.value,
                'confianca': round(s.confianca * 100, 1),
                'justificativa': s.justificativa,
                'alternativas': s.alternativas or []
            }
            for s in sugestoes
        ]


