import requests
from typing import Dict, List

class BuscadorAtributosML:
    """
    Integração com API do Mercado Livre para buscar atributos por categoria
    
    Documentação oficial:
    https://developers.mercadolibre.com.br/pt_br/itens-e-buscas
    """
    
    BASE_URL = "https://api.mercadolibre.com"
    
    def __init__(self):
        pass
    
    def get_atributos_categoria(self, category_id: str) -> List[Dict]:
        """
        Busca todos os atributos de uma categoria
        
        Endpoint: GET /categories/{category_id}/attributes
        
        Args:
            category_id: ID da categoria (ex: MLB1649 para Computação > Notebooks)
            
        Returns:
            Lista de atributos com metadados
        """
        url = f"{self.BASE_URL}/categories/{category_id}/attributes"
        
        try:
            response = requests.get(url, timeout=10)
            response.raise_for_status()
            atributos = response.json()
            
            # Processar e enriquecer dados
            return [self._processar_atributo(attr) for attr in atributos]
        
        except requests.exceptions.RequestException as e:
            print(f"❌ Erro ao buscar atributos: {e}")
            return []
    
    def _processar_atributo(self, attr: Dict) -> Dict:
        """Processa e estrutura dados do atributo"""
        tags = attr.get('tags', {})
        
        return {
            'id': attr['id'],
            'nome': attr['name'],
            'tipo': attr['value_type'],  # string, number, boolean, list
            'obrigatorio': tags.get('required', False),
            'permite_variacao': tags.get('allow_variations', False),
            'visivel_busca': tags.get('defines_picture', False),
            'valores_possiveis': self._extrair_valores_possiveis(attr),
            'hint': attr.get('hint', ''),
            'exemplo': attr.get('default_value', None)
        }
    
    def _extrair_valores_possiveis(self, attr: Dict) -> List[str]:
        """Extrai lista de valores possíveis para atributos tipo 'list'"""
        if attr['value_type'] == 'list':
            values = attr.get('values', [])
            return [v['name'] for v in values]
        return []
    
    def buscar_categoria_por_nome(self, nome_produto: str, site_id: str = "MLB") -> str:
        """
        Prediz categoria baseado no nome do produto
        
        Args:
            nome_produto: Nome/título do produto
            site_id: Site do ML (MLB para Brasil)
            
        Returns:
            ID da categoria prevista
        """
        url = f"{self.BASE_URL}/sites/{site_id}/domain_discovery/search"
        params = {'q': nome_produto, 'limit': 1}
        
        try:
            response = requests.get(url, params=params, timeout=10)
            response.raise_for_status()
            data = response.json()
            
            if data:
                return data[0]['category_id']
        
        except Exception as e:
            print(f"❌ Erro ao prever categoria: {e}")
        
        return None


