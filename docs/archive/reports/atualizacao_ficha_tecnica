## 4. 🧠 Módulo 2: Extração Inteligente de Palavras-Chave

### 4.1 Extração do Título (NLP)

```python
import spacy
import re
from typing import Dict, List, Optional

class ExtratorNLP:
    """
    Extrai informações estruturadas do título usando NLP
    """
    
    # Padrões regex para especificações técnicas
    PATTERNS = {
        'ram': re.compile(r'(\d+)\s*GB\s*(?:RAM|DDR\d?|Memória)', re.IGNORECASE),
        'storage': re.compile(r'(?:SSD|HD|HDD)?\s*(\d+)\s*(?:GB|TB)', re.IGNORECASE),
        'screen': re.compile(r'(?:Tela|Display|Polegadas)?\s*(\d+\.?\d*)\s*(?:"|pol|polegadas)?', re.IGNORECASE),
        'processor': re.compile(r'(Intel Core i[3579]|AMD Ryzen [3579]|Pentium|Celeron)', re.IGNORECASE),
        'generation': re.compile(r'(\d{1,2})ª?\s*(?:Geração|Gen)', re.IGNORECASE),
        'color': re.compile(r'(?:Cor:?\s*)?(\w+)\s*$', re.IGNORECASE),
    }
    
    # Marcas conhecidas (expandir conforme necessário)
    MARCAS_CONHECIDAS = {
        'Dell', 'HP', 'Lenovo', 'Asus', 'Acer', 'Samsung', 'LG', 
        'Apple', 'Positivo', 'Vaio', 'Compaq', 'Microsoft', 'Avell'
    }
    
    def __init__(self):
        """Inicializa o modelo spaCy para português"""
        try:
            self.nlp = spacy.load("pt_core_news_lg")
        except OSError:
            print("Baixando modelo spaCy para português...")
            import subprocess
            subprocess.run(["python", "-m", "spacy", "download", "pt_core_news_lg"])
            self.nlp = spacy.load("pt_core_news_lg")
    
    def extrair(self, titulo: str) -> Dict:
        """
        Extrai todas as informações possíveis do título
        
        Args:
            titulo: Título do anúncio
            
        Returns:
            Dicionário com informações extraídas e nível de confiança
        """
        doc = self.nlp(titulo)
        
        resultado = {
            'titulo_original': titulo,
            'extraido': {},
            'confianca': {}
        }
        
        # 1. Extrair marca (usando NER e lista conhecida)
        marca = self._extrair_marca(doc, titulo)
        if marca:
            resultado['extraido']['BRAND'] = marca
            resultado['confianca']['BRAND'] = 0.9
        
        # 2. Extrair modelo (primeira palavra após marca)
        modelo = self._extrair_modelo(titulo, marca)
        if modelo:
            resultado['extraido']['MODEL'] = modelo
            resultado['confianca']['MODEL'] = 0.8
        
        # 3. Extrair especificações técnicas usando regex
        specs = self._extrair_especificacoes(titulo)
        resultado['extraido'].update(specs['extraido'])
        resultado['confianca'].update(specs['confianca'])
        
        # 4. Extrair condição (Novo/Usado)
        condicao = self._extrair_condicao(titulo)
        if condicao:
            resultado['extraido']['ITEM_CONDITION'] = condicao
            resultado['confianca']['ITEM_CONDITION'] = 0.95
        
        return resultado
    
    def _extrair_marca(self, doc, titulo: str) -> Optional[str]:
        """Extrai marca usando NER + lista conhecida"""
        # Método 1: NER do spaCy
        for ent in doc.ents:
            if ent.label_ == "ORG" and ent.text in self.MARCAS_CONHECIDAS:
                return ent.text
        
        # Método 2: Busca direta na lista conhecida
        palavras = titulo.split()
        for palavra in palavras[:5]:  # Marca geralmente está no início
            palavra_limpa = palavra.strip(',.!?()[]')
            if palavra_limpa in self.MARCAS_CONHECIDAS:
                return palavra_limpa
        
        return None
    
    def _extrair_modelo(self, titulo: str, marca: Optional[str]) -> Optional[str]:
        """Extrai modelo (palavras logo após a marca)"""
        if not marca:
            return None
        
        # Encontra posição da marca no título
        marca_lower = marca.lower()
        titulo_lower = titulo.lower()
        
        if marca_lower not in titulo_lower:
            return None
        
        # Pega 2-3 palavras após a marca
        pos = titulo_lower.index(marca_lower) + len(marca_lower)
        resto = titulo[pos:].strip()
        
        # Extrai até encontrar número ou palavra técnica
        palavras = resto.split()
        modelo_palavras = []
        
        for palavra in palavras[:3]:
            # Para se encontrar especificação técnica
            if re.search(r'\d+GB|\d+TB|i[3579]|Ryzen', palavra, re.IGNORECASE):
                break
            modelo_palavras.append(palavra)
        
        if modelo_palavras:
            return ' '.join(modelo_palavras)
        
        return None
    
    def _extrair_especificacoes(self, titulo: str) -> Dict:
        """Extrai especificações técnicas usando regex"""
        extraido = {}
        confianca = {}
        
        # RAM
        match_ram = self.PATTERNS['ram'].search(titulo)
        if match_ram:
            extraido['RAM_MEMORY'] = f"{match_ram.group(1)} GB"
            confianca['RAM_MEMORY'] = 0.95
        
        # Storage (SSD/HD)
        match_storage = self.PATTERNS['storage'].search(titulo)
        if match_storage:
            valor = match_storage.group(1)
            unidade = "TB" if "TB" in match_storage.group(0).upper() else "GB"
            extraido['STORAGE_CAPACITY'] = f"{valor} {unidade}"
            confianca['STORAGE_CAPACITY'] = 0.9
            
            # Tipo de armazenamento
            if "SSD" in titulo.upper():
                extraido['STORAGE_TYPE'] = "SSD"
                confianca['STORAGE_TYPE'] = 0.95
            elif "HD" in titulo.upper() or "HDD" in titulo.upper():
                extraido['STORAGE_TYPE'] = "HD"
                confianca['STORAGE_TYPE'] = 0.95
        
        # Tela
        match_screen = self.PATTERNS['screen'].search(titulo)
        if match_screen:
            extraido['SCREEN_SIZE'] = f"{match_screen.group(1)} polegadas"
            confianca['SCREEN_SIZE'] = 0.85
        
        # Processador
        match_processor = self.PATTERNS['processor'].search(titulo)
        if match_processor:
            extraido['PROCESSOR_MODEL'] = match_processor.group(1)
            confianca['PROCESSOR_MODEL'] = 0.9
        
        # Geração do processador
        match_gen = self.PATTERNS['generation'].search(titulo)
        if match_gen:
            extraido['PROCESSOR_GENERATION'] = f"{match_gen.group(1)}ª Geração"
            confianca['PROCESSOR_GENERATION'] = 0.85
        
        # Cor (geralmente no final)
        palavras = titulo.split()
        cores_comuns = ['Preto', 'Prata', 'Cinza', 'Branco', 'Azul', 'Vermelho', 'Rosa']
        for cor in cores_comuns:
            if cor in palavras:
                extraido['COLOR'] = cor
                confianca['COLOR'] = 0.8
                break
        
        return {'extraido': extraido, 'confianca': confianca}
    
    def _extrair_condicao(self, titulo: str) -> Optional[str]:
        """Identifica se o produto é novo ou usado"""
        titulo_lower = titulo.lower()
        
        if any(palavra in titulo_lower for palavra in ['novo', 'lacrado', 'original']):
            return "Novo"
        elif any(palavra in titulo_lower for palavra in ['usado', 'seminovo', 'vitrine']):
            return "Usado"
        
        # Se não mencionar, assume novo (padrão do ML)
        return "Novo"


