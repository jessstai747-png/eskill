## 3. 📊 Módulo 1: Análise de Lacunas

### 3.1 Identificador de Campos Vazios

```python
import requests
from typing import Dict, List, Optional
from dataclasses import dataclass
from enum import Enum

class PrioridadeSEO(Enum):
    """Níveis de prioridade para SEO do Mercado Livre"""
    CRITICA = 10    # Atributos obrigatórios da categoria
    ALTA = 7        # Atributos que afetam filtros principais
    MEDIA = 5       # Atributos visíveis na busca
    BAIXA = 3       # Atributos complementares

@dataclass
class Lacuna:
    """Representa um atributo faltante na ficha técnica"""
    attribute_id: str
    attribute_name: str
    tipo: str  # string, number, boolean, list
    obrigatorio: bool
    valores_possiveis: Optional[List[str]]
    prioridade_seo: int
    impacto_busca: str
    categoria_relacionada: str

class AnalisadorLacunas:
    """
    Identifica campos vazios e prioriza por impacto no SEO
    """
    
    # Pesos SEO por tipo de atributo (baseado em análise do algoritmo ML)
    PESOS_SEO = {
        'BRAND': 10,           # Marca
        'MODEL': 9,            # Modelo
        'LINE': 8,             # Linha do produto
        'ITEM_CONDITION': 10,  # Novo/Usado
        'WARRANTY_TYPE': 7,    # Tipo de garantia
        'COLOR': 6,            # Cor
        'MAIN_COLOR': 6,       # Cor principal
        'SIZE': 7,             # Tamanho
        'MATERIAL': 5,         # Material
        'GENDER': 6,           # Gênero
    }
    
    def __init__(self, access_token: str):
        self.access_token = access_token
        self.base_url = "https://api.mercadolibre.com"
    
    def analisar_anuncio(self, item_id: str) -> Dict:
        """
        Analisa um anúncio e identifica todas as lacunas
        
        Args:
            item_id: ID do item no Mercado Livre (ex: MLB123456789)
            
        Returns:
            Dicionário com análise completa de lacunas
        """
        # 1. Buscar dados do anúncio
        item = self._get_item(item_id)
        
        # 2. Buscar atributos obrigatórios da categoria
        category_id = item['category_id']
        atributos_categoria = self._get_category_attributes(category_id)
        
        # 3. Identificar atributos presentes no anúncio
        atributos_preenchidos = {
            attr['id']: attr['value_name'] 
            for attr in item.get('attributes', [])
        }
        
        # 4. Encontrar lacunas
        lacunas = []
        for attr in atributos_categoria:
            if attr['id'] not in atributos_preenchidos:
                lacuna = Lacuna(
                    attribute_id=attr['id'],
                    attribute_name=attr['name'],
                    tipo=attr['value_type'],
                    obrigatorio=attr.get('tags', {}).get('required', False),
                    valores_possiveis=self._get_possible_values(attr),
                    prioridade_seo=self._calcular_prioridade_seo(attr),
                    impacto_busca=self._avaliar_impacto_busca(attr),
                    categoria_relacionada=category_id
                )
                lacunas.append(lacuna)
        
        # 5. Ordenar por prioridade
        lacunas_ordenadas = sorted(
            lacunas, 
            key=lambda x: (x.obrigatorio, x.prioridade_seo), 
            reverse=True
        )
        
        # 6. Calcular métricas
        total_atributos = len(atributos_categoria)
        preenchidos = len(atributos_preenchidos)
        completude = (preenchidos / total_atributos * 100) if total_atributos > 0 else 0
        
        return {
            'item_id': item_id,
            'titulo': item['title'],
            'categoria': category_id,
            'metricas': {
                'total_atributos': total_atributos,
                'atributos_preenchidos': preenchidos,
                'lacunas_encontradas': len(lacunas_ordenadas),
                'completude_percentual': round(completude, 2),
                'score_seo_atual': self._calcular_score_seo(atributos_preenchidos, atributos_categoria)
            },
            'lacunas': [
                {
                    'id': l.attribute_id,
                    'nome': l.attribute_name,
                    'tipo': l.tipo,
                    'obrigatorio': l.obrigatorio,
                    'prioridade': l.prioridade_seo,
                    'impacto': l.impacto_busca,
                    'valores_possiveis': l.valores_possiveis
                }
                for l in lacunas_ordenadas
            ]
        }
    
    def _get_item(self, item_id: str) -> Dict:
        """Busca dados do anúncio na API do ML"""
        url = f"{self.base_url}/items/{item_id}"
        headers = {'Authorization': f'Bearer {self.access_token}'}
        response = requests.get(url, headers=headers)
        response.raise_for_status()
        return response.json()
    
    def _get_category_attributes(self, category_id: str) -> List[Dict]:
        """
        Busca atributos da categoria
        URL: https://api.mercadolibre.com/categories/{category_id}/attributes
        """
        url = f"{self.base_url}/categories/{category_id}/attributes"
        response = requests.get(url)
        response.raise_for_status()
        return response.json()
    
    def _get_possible_values(self, attribute: Dict) -> Optional[List[str]]:
        """Extrai valores possíveis para atributos de lista"""
        if attribute['value_type'] == 'list':
            values = attribute.get('values', [])
            return [v['name'] for v in values[:20]]  # Limita a 20 valores
        return None
    
    def _calcular_prioridade_seo(self, attribute: Dict) -> int:
        """Calcula prioridade SEO baseado no tipo de atributo"""
        attr_id = attribute['id']
        
        # Prioridade máxima para obrigatórios
        if attribute.get('tags', {}).get('required', False):
            return PrioridadeSEO.CRITICA.value
        
        # Usa tabela de pesos conhecidos
        if attr_id in self.PESOS_SEO:
            return self.PESOS_SEO[attr_id]
        
        # Atributos com allow_variations têm impacto médio
        if attribute.get('tags', {}).get('allow_variations', False):
            return PrioridadeSEO.MEDIA.value
        
        # Outros atributos têm prioridade baixa
        return PrioridadeSEO.BAIXA.value
    
    def _avaliar_impacto_busca(self, attribute: Dict) -> str:
        """Avalia impacto no motor de busca"""
        prioridade = self._calcular_prioridade_seo(attribute)
        
        if prioridade >= PrioridadeSEO.CRITICA.value:
            return "🔴 CRÍTICO - Afeta ranqueamento principal"
        elif prioridade >= PrioridadeSEO.ALTA.value:
            return "🟠 ALTO - Usado em filtros importantes"
        elif prioridade >= PrioridadeSEO.MEDIA.value:
            return "🟡 MÉDIO - Melhora visibilidade"
        else:
            return "🟢 BAIXO - Informação complementar"
    
    def _calcular_score_seo(self, preenchidos: Dict, todos: List[Dict]) -> int:
        """
        Calcula score SEO ponderado (0-100)
        
        Fórmula: Σ(peso_atributo_preenchido) / Σ(peso_total) * 100
        """
        peso_total = sum(self._calcular_prioridade_seo(attr) for attr in todos)
        peso_preenchido = sum(
            self._calcular_prioridade_seo(attr) 
            for attr in todos 
            if attr['id'] in preenchidos
        )
        
        if peso_total == 0:
            return 100
        
        return round((peso_preenchido / peso_total) * 100)


# ============= EXEMPLO DE USO =============

if __name__ == "__main__":
    # Inicializar analisador
    analisador = AnalisadorLacunas(access_token="APP_USR-XXXXX")
    
    # Analisar um notebook
    resultado = analisador.analisar_anuncio("MLB1234567890")
    
    print(f"📦 Anúncio: {resultado['titulo']}")
    print(f"📊 Completude: {resultado['metricas']['completude_percentual']}%")
    print(f"🎯 Score SEO: {resultado['metricas']['score_seo_atual']}/100")
    print(f"\n🔍 Lacunas encontradas: {resultado['metricas']['lacunas_encontradas']}")
    
    for lacuna in resultado['lacunas'][:5]:  # Top 5
        print(f"\n  • {lacuna['nome']} ({lacuna['id']})")
        print(f"    Prioridade: {lacuna['prioridade']}/10")
        print(f"    {lacuna['impacto']}")
```

