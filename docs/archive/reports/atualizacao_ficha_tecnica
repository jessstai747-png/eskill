### 4.3 Análise de Tendências (ML Trends)

```python
import requests
from typing import List, Dict
from datetime import datetime, timedelta

class AnalisadorTendencias:
    """
    Analisa tendências de busca no Mercado Livre
    
    Combina ML Trends API + Google Trends (opcional)
    """
    
    ML_TRENDS_URL = "https://api.mercadolibre.com/trends/{site_id}/{category_id}"
    
    def __init__(self):
        self.cache = {}
    
    def obter_termos_tendencia(self, category_id: str, site_id: str = "MLB") -> List[Dict]:
        """
        Busca termos em tendência para uma categoria
        
        Args:
            category_id: ID da categoria do ML
            site_id: Site (MLB para Brasil)
            
        Returns:
            Lista de termos com volume de busca
        """
        cache_key = f"{site_id}_{category_id}"
        
        # Usar cache se disponível (válido por 24h)
        if cache_key in self.cache:
            timestamp, dados = self.cache[cache_key]
            if datetime.now() - timestamp < timedelta(hours=24):
                return dados
        
        # Buscar na API
        url = self.ML_TRENDS_URL.format(site_id=site_id, category_id=category_id)
        
        try:
            response = requests.get(url, timeout=10)
            response.raise_for_status()
            dados = response.json()
            
            termos = self._processar_tendencias(dados)
            
            # Cachear resultado
            self.cache[cache_key] = (datetime.now(), termos)
            
            return termos
        
        except Exception as e:
            print(f"⚠️ Erro ao buscar tendências: {e}")
            return []
    
    def _processar_tendencias(self, dados: Dict) -> List[Dict]:
        """Processa resposta da API de tendências"""
        termos = []
        
        # A estrutura exata depende da API do ML
        # Exemplo hipotético baseado em APIs similares
        for item in dados.get('trends', [])[:20]:
            termos.append({
                'termo': item.get('keyword', ''),
                'volume': item.get('search_volume', 0),
                'crescimento': item.get('growth_rate', 0),
                'relevancia': item.get('relevance_score', 0)
            })
        
        return sorted(termos, key=lambda x: x['relevancia'], reverse=True)
    
    def extrair_keywords_relevantes(self, termos_tendencia: List[Dict], titulo_produto: str) -> List[str]:
        """
        Filtra keywords de tendência relevantes para o produto
        
        Args:
            termos_tendencia: Lista de termos em tendência
            titulo_produto: Título do produto para contexto
            
        Returns:
            Lista de keywords relevantes
        """
        titulo_lower = titulo_produto.lower()
        palavras_titulo = set(titulo_lower.split())
        
        keywords_relevantes = []
        
        for termo_info in termos_tendencia:
            termo = termo_info['termo'].lower()
            palavras_termo = set(termo.split())
            
            # Verificar overlap: pelo menos 1 palavra em comum
            if palavras_termo & palavras_titulo:
                keywords_relevantes.append({
                    'keyword': termo_info['termo'],
                    'razao': f"Overlap com título (volume: {termo_info['volume']:,})",
                    'volume': termo_info['volume']
                })
        
        return keywords_relevantes[:5]  # Top 5


# ============= EXEMPLO DE USO =============

if __name__ == "__main__":
