# ============================================================================
# CRONTAB: Catalog Clone Workers (Multi-Account Batch Cloning)
# ============================================================================
#
# Instalação:
#   crontab -e
#   Adicione as linhas abaixo (ajuste o caminho do projeto)
#
# Variáveis de ambiente:
#   Certifique-se de que o .env está configurado corretamente
#
# Logs:
#   storage/logs/catalog-clone-worker.log
#   storage/logs/clone-post-actions-worker.log
#
# ============================================================================

# Define o diretório do projeto
PROJECT_DIR=/home/eskill/htdocs/eskill.com.br

# ============================================================================
# CATALOG CLONE WORKER - Processa jobs de clonagem em lote
# Frequência: A cada 1 minuto (processa jobs pendentes)
# ============================================================================
* * * * * cd $PROJECT_DIR && /usr/bin/php bin/catalog-clone-worker.php --once >> storage/logs/cron-catalog-clone.log 2>&1

# ============================================================================
# CLONE POST-ACTIONS WORKER - Executa ações pós-clone
# (Tech Sheet, SEO Optimize, Pricing Apply, Activate)
# Frequência: A cada 2 minutos
# ============================================================================
*/2 * * * * cd $PROJECT_DIR && /usr/bin/php bin/clone-post-actions-worker.php --once >> storage/logs/cron-post-actions.log 2>&1

# ============================================================================
# RECOVERY: Recupera jobs travados (stuck)
# Frequência: A cada 15 minutos
# ============================================================================
*/15 * * * * cd $PROJECT_DIR && /usr/bin/php bin/catalog-clone-worker.php --recover-stuck >> storage/logs/cron-recovery.log 2>&1

# ============================================================================
# HEALTH CHECK: Monitora saúde dos workers
# Frequência: A cada 5 minutos
# ============================================================================
*/5 * * * * cd $PROJECT_DIR && /usr/bin/php bin/clone-health-monitor.php >> storage/logs/cron-health.log 2>&1

# ============================================================================
# CLEANUP: Limpa logs antigos e jobs completados
# Frequência: Diariamente às 3:00 AM
# ============================================================================
0 3 * * * cd $PROJECT_DIR && /usr/bin/php bin/cleanup-clone-data.php --days=30 >> storage/logs/cron-cleanup.log 2>&1

# ============================================================================
# METRICS: Gera relatórios de métricas diárias
# Frequência: Diariamente às 1:00 AM
# ============================================================================
0 1 * * * cd $PROJECT_DIR && /usr/bin/php bin/generate-clone-metrics-report.php >> storage/logs/cron-metrics.log 2>&1

# ============================================================================
# NOTES:
# - Ajuste a frequência conforme necessário
# - Em produção com alto volume, considere rodar múltiplas instâncias do worker
# - Use --limit=N para processar N itens por vez (ex: --limit=10)
# - Para debug, adicione --verbose nas chamadas
# - Monitore os logs regularmente
# ============================================================================
